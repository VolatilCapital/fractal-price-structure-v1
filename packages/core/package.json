{
  "name": "@fractal-price-structure/core",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome lint src/",
    "format": "biome format src/",
    "clean": "rimraf dist"
  },
  "keywords": ["fractal", "price-structure", "trading", "technical-analysis"],
  "author": "",
  "license": "ISC",
  "description": "Core library for fractal price structure analysis",
  "dependencies": {
    "trading-core-type": "github:VolatilCapital/trading-core-type",
    "axios": "^1.12.2",
    "big.js": "^7.0.1",
    "luxon": "^3.7.2",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/big.js": "^6.2.2",
    "@types/luxon": "^3.7.1",
    "@types/node": "^24.9.1",
    "@types/uuid": "^10.0.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
