{
  "name": "@fractal-price-structure/visualizer",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "build:web": "vite build",
    "dev": "vite",
    "dev:terminal": "tsx src/btc-demo.ts",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome lint src/",
    "format": "biome format src/",
    "clean": "rimraf dist dist-web"
  },
  "keywords": ["fractal", "visualizer", "trading", "vue", "observable-plot"],
  "author": "",
  "license": "ISC",
  "description": "Visualization tools for fractal price structures - web app and terminal",
  "dependencies": {
    "@fractal-price-structure/core": "workspace:*",
    "@mdi/font": "^7.4.47",
    "@observablehq/plot": "^0.6.17",
    "vue": "^3.5.30",
    "vuetify": "^4.0.1"
  },
  "devDependencies": {
    "@types/node": "^24.9.1",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vue/test-utils": "^2.4.6",
    "rimraf": "^6.1.3",
    "sass": "^1.97.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-vuetify": "^2.1.3",
    "vue-tsc": "^3.2.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
