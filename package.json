{
  "name": "fractal-price-structure-v1",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "biome lint packages/",
    "lint:fix": "biome lint --write packages/",
    "format": "biome format packages/",
    "format:fix": "biome format --write packages/",
    "check": "biome check packages/",
    "check:fix": "biome check --write packages/",
    "clean": "pnpm -r clean",
    "dev": "pnpm --filter @fractal-price-structure/core dev",
    "visualizer:dev": "pnpm --filter @fractal-price-structure/visualizer dev",
    "visualizer:build": "pnpm --filter @fractal-price-structure/visualizer build:web",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "keywords": [
    "fractal",
    "price-structure",
    "trading",
    "technical-analysis"
  ],
  "author": "",
  "license": "ISC",
  "description": "V1 — Analyse fractale de structures de prix (archivé). Algo PriceMove / FractalEngine.",
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@playwright/test": "^1.58.2",
    "@types/node": "^24.12.0",
    "@vitest/coverage-v8": "^4.1.2",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
